# -t 3600: Rescan every 1 hour
# -Z: Scan .ddebs, .tar.xz (source code)
DEBUGINFOD_OPTIONS="-c 16 -t 3600 -Z.ddeb='(bsdtar -O -x -f - data.tar.*)<' -Z.deb='(bsdtar -O -x -f - data.tar.*)<' -Z.tar.xz"


